+        pass
+
+    @abstractmethod
+    def fetch(self, **options: object) -> List[ContentItem]:
+        """в•ЁРҜв•Ёв•ӣв•Ёв•—в•ӨР“в•ӨР—в•Ёв••в•ӨР’в•ӨРң в•ӨР‘в•Ёв”җв•Ёв••в•ӨР‘в•Ёв•ӣв•Ёв•‘ в•ӨРқв•Ёв•—в•Ёв•Ўв•Ёв•қв•Ёв•Ўв•Ёв•ңв•ӨР’в•Ёв•ӣв•Ёв–“ в•Ёв•‘в•Ёв•ӣв•Ёв•ңв•ӨР’в•Ёв•Ўв•Ёв•ңв•ӨР’в•Ёв–‘ в•Ёв••в•Ёв•– в•Ёв••в•ӨР‘в•ӨР’в•Ёв•ӣв•ӨР—в•Ёв•ңв•Ёв••в•Ёв•‘в•Ёв–‘.
+
+        Returns:
+            в•ЁРұв•Ёв”җв•Ёв••в•ӨР‘в•Ёв•ӣв•Ёв•‘ ContentItem. в•ЁРҜв•ӨР“в•ӨР‘в•ӨР’в•Ёв•ӣв•Ёв•Ј в•ӨР‘в•Ёв”җв•Ёв••в•ӨР‘в•Ёв•ӣв•Ёв•‘ в•Ёв”җв•ӨРҗв•Ёв•• в•Ёв•ӣв•ӨР’в•ӨР‘в•ӨР“в•ӨР’в•ӨР‘в•ӨР’в•Ёв–“в•Ёв••в•Ёв•• в•Ёв”Өв•Ёв–‘в•Ёв•ңв•Ёв•ңв•ӨРӣв•ӨР•.
+        """
