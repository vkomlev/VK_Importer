+"""DAO в•Ёв”Өв•Ёв•—в•ӨРҹ content_hub.publication в•Ёв•• content_hub.link_map (PostgreSQL)."""
+
+import logging
+import uuid
+from datetime import datetime, timezone
+from typing import Optional
+
+from .models import ContentHubConfig, LinkMapPayload, PublicationPayload
+
+logger = logging.getLogger(__name__)
+
+# в•ЁРӘв•Ёв•—в•Ёв–‘в•ӨР‘в•ӨР‘в•ӨРӣ в•Ёв•ӣв•ӨРҳв•Ёв••в•Ёв–’в•Ёв•ӣв•Ёв•‘ в•ЁРЎв•ЁРӨ в•Ёв”Өв•Ёв•—в•ӨРҹ в•Ёв•‘в•Ёв•—в•Ёв–‘в•ӨР‘в•ӨР‘в•Ёв••в•ӨР”в•Ёв••в•Ёв•‘в•Ёв–‘в•ӨР–в•Ёв••в•Ёв•• (в•ЁРІв•ЁР§ 5.4)
+RETRYABLE_EXCEPTIONS = (
+    "OperationalError",
+    "InterfaceError",
+    "connection",
+    "timeout",
+    "could not connect",
+    "connection reset",
+    "deadlock",
+)
+NON_RETRYABLE_EXCEPTIONS = (
+    "IntegrityError",
+    "ProgrammingError",
+    "DataError",
+    "unique constraint",
+    "duplicate key",
+    "column",
+    "relation \"content_hub",
+)
+
+
+def _error_class(exc: Exception) -> str:
+    """в•ЁРӘв•Ёв•—в•Ёв–‘в•ӨР‘в•ӨР‘в•Ёв••в•ӨР”в•Ёв••в•ӨР–в•Ёв••в•ӨРҗв•Ёв•ӣв•Ёв–“в•Ёв–‘в•ӨР’в•ӨРң в•Ёв•ӣв•ӨРҳв•Ёв••в•Ёв–’в•Ёв•‘в•ӨР“: retryable / non_retryable."""
+    msg = (str(exc) or "").lower()
+    name = type(exc).__name__
+    for s in NON_RETRYABLE_EXCEPTIONS:
+        if s.lower() in msg or s in name:
+            return "non_retryable"
+    for s in RETRYABLE_EXCEPTIONS:
+        if s.lower() in msg or s in name:
+            return "retryable"
+    return "unknown"
+
+
+def _log_canonical(
+    run_id: str,
+    global_uid: str,
+    destination: str,
+    status: str,
+    error_class: Optional[str] = None,
+    dry_run: bool = False,
+    message: str = "",
+    level: int = logging.INFO,
+) -> None:
+    """Structured log в•Ёв”җв•Ёв•ӣ в•ЁРІв•ЁР§ 5.4."""
+    extra = {
+        "run_id": run_id,
+        "global_uid": global_uid,
+        "destination": destination,
+        "status": status,
+        "error_class": error_class,
+        "dry_run": dry_run,
+    }
+    logger.log(level, "content_hub canonical write: %s", message or "ok", extra=extra)
+
+
+class ContentHubRepository:
+    """в•ЁР°в•Ёв•Ўв•Ёв”җв•Ёв•ӣв•Ёв•–в•Ёв••в•ӨР’в•Ёв•ӣв•ӨРҗв•Ёв••в•Ёв•Ј в•Ёв”Өв•Ёв•—в•ӨРҹ upsert в•Ёв–“ content_hub.publication в•Ёв•• content_hub.link_map."""
+
+    def __init__(self, config: ContentHubConfig, run_id: Optional[str] = None):
+        self.config = config
+        self.run_id = run_id or str(uuid.uuid4())[:8]
+
+    def _conn(self):
+        if not self.config.dsn:
+            raise ValueError("CONTENT_HUB_PG_DSN в•Ёв•ңв•Ёв•Ў в•Ёв•–в•Ёв–‘в•Ёв”Өв•Ёв–‘в•Ёв•ң")
+        try:
+            import psycopg2
+            return psycopg2.connect(self.config.dsn)
+        except Exception as e:
+            cls = _error_class(e)
+            _log_canonical(
+                self.run_id, "", "vk", "failed",
+                error_class=cls, dry_run=self.config.dry_run,
+                message=f"connect failed: {e}", level=logging.ERROR,
+            )
+            raise
+
+    def upsert_publication(self, payload: PublicationPayload) -> None:
+        """в•ЁРЁв•Ёв”Өв•Ёв•Ўв•Ёв•қв•Ёв”җв•Ёв•ӣв•ӨР’в•Ёв•Ўв•Ёв•ңв•ӨР’в•Ёв•ңв•ӨРӣв•Ёв•Ј upsert в•Ёв–“ content_hub.publication в•Ёв”җв•Ёв•ӣ (global_uid, destination)."""
+        if self.config.dry_run:
+            _log_canonical(
+                self.run_id, payload.global_uid, payload.destination, payload.status,
+                dry_run=True, message="[dry-run] publication upsert skipped",
+            )
+            return
+        conn = self._conn()
+        try:
+            with conn.cursor() as cur:
+                now = datetime.now(timezone.utc)
+                cur.execute(
+                    """
+                    INSERT INTO content_hub.publication
+                    (global_uid, destination, remote_url, remote_id, status, error, published_at, created_at, updated_at)
+                    VALUES (%s, %s, %s, %s, %s, %s, %s, %s, %s)
+                    ON CONFLICT (global_uid, destination) DO UPDATE SET
+                    remote_url = EXCLUDED.remote_url,
+                    remote_id = EXCLUDED.remote_id,
+                    status = EXCLUDED.status,
+                    error = EXCLUDED.error,
+                    published_at = EXCLUDED.published_at,
+                    updated_at = EXCLUDED.updated_at
+                    """,
+                    (
+                        payload.global_uid,
+                        payload.destination,
+                        payload.remote_url,
+                        payload.remote_id,
+                        payload.status,
+                        payload.error,
+                        payload.published_at,
+                        now,
+                        now,
+                    ),
+                )
+            conn.commit()
+            _log_canonical(
+                self.run_id, payload.global_uid, payload.destination, payload.status,
+                dry_run=False, message="publication upserted",
+            )
+        except Exception as e:
+            conn.rollback()
+            cls = _error_class(e)
+            _log_canonical(
+                self.run_id, payload.global_uid, payload.destination, "failed",
+                error_class=cls, dry_run=False, message=f"publication upsert failed: {e}",
+                level=logging.ERROR,
+            )
+            raise
+        finally:
+            conn.close()
+
+    def upsert_link_map(self, payload: LinkMapPayload) -> None:
+        """в•ЁРЁв•Ёв”Өв•Ёв•Ўв•Ёв•қв•Ёв”җв•Ёв•ӣв•ӨР’в•Ёв•Ўв•Ёв•ңв•ӨР’в•Ёв•ңв•ӨРӣв•Ёв•Ј upsert в•Ёв–“ content_hub.link_map в•Ёв”җв•Ёв•ӣ (source_global_uid, destination). в•ЁРЎв•Ёв•Ўв•Ёв•– updated_at (в•Ёв•‘в•Ёв•ӣв•Ёв•—в•Ёв•ӣв•Ёв•ңв•Ёв•‘в•Ёв•• в•Ёв•ңв•Ёв•Ўв•ӨР’ в•Ёв–“ в•ӨР‘в•ӨР•в•Ёв•Ўв•Ёв•қв•Ёв•Ў)."""
+        if self.config.dry_run:
+            _log_canonical(
+                self.run_id, payload.source_global_uid, payload.destination, "link_map",
+                dry_run=True, message="[dry-run] link_map upsert skipped",
+            )
+            return
+        conn = self._conn()
+        try:
+            with conn.cursor() as cur:
+                now = datetime.now(timezone.utc)
+                cur.execute(
+                    """
+                    INSERT INTO content_hub.link_map
+                    (source_global_uid, destination, remote_id, remote_url, created_at)
+                    VALUES (%s, %s, %s, %s, %s)
+                    ON CONFLICT (source_global_uid, destination) DO UPDATE SET
+                    remote_id = EXCLUDED.remote_id,
+                    remote_url = EXCLUDED.remote_url
+                    """,
+                    (
+                        payload.source_global_uid,
+                        payload.destination,
+                        payload.remote_id,
+                        payload.remote_url,
+                        now,
+                    ),
+                )
+            conn.commit()
+            _log_canonical(
+                self.run_id, payload.source_global_uid, payload.destination, "link_map",
+                dry_run=False, message="link_map upserted",
+            )
+        except Exception as e:
+            conn.rollback()
+            cls = _error_class(e)
+            _log_canonical(
+                self.run_id, payload.source_global_uid, payload.destination, "failed",
+                error_class=cls, dry_run=False, message=f"link_map upsert failed: {e}",
+                level=logging.ERROR,
+            )
+            raise
+        finally:
+            conn.close()
