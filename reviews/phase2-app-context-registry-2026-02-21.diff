+def write_summary(
+    command: str,
+    exit_code: int,
+    stats: dict[str, Any],
+    warnings: list[str],
+    errors: list[str],
+    duration_sec: Optional[float] = None,
+) -> None:
+    """в•ЁР§в•Ёв–‘в•Ёв”җв•Ёв••в•ӨР‘в•Ёв–‘в•ӨР’в•ӨРң в•Ёв••в•ӨР’в•Ёв•ӣв•Ёв”Ӯ в•Ёв•‘в•Ёв•ӣв•Ёв•қв•Ёв–‘в•Ёв•ңв•Ёв”Өв•ӨРӣ в•Ёв–“ logs/last_summary.json в•Ёв”Өв•Ёв•—в•ӨРҹ в•Ёв”җв•Ёв–‘в•Ёв•Јв•Ёв”җв•Ёв•—в•Ёв–‘в•Ёв•Јв•Ёв•ңв•Ёв•ӣв•Ёв–“."""
+    SUMMARY_FILE.parent.mkdir(parents=True, exist_ok=True)
+    payload = {
+        "command": command,
+        "exit_code": exit_code,
+        "ts_end": datetime.now(timezone.utc).isoformat(),
+        "ok": exit_code == EXIT_SUCCESS,
+        "stats": stats,
+        "warnings": warnings,
+        "errors": errors,
+    }
+    if duration_sec is not None:
+        payload["duration_sec"] = round(duration_sec, 2)
+    try:
+        SUMMARY_FILE.write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding="utf-8")
+    except Exception as e:
+        logger.warning("в•ЁРӯв•Ёв•Ў в•ӨР“в•Ёв”Өв•Ёв–‘в•Ёв•—в•Ёв•ӣв•ӨР‘в•ӨРң в•Ёв•–в•Ёв–‘в•Ёв”җв•Ёв••в•ӨР‘в•Ёв–‘в•ӨР’в•ӨРң summary: %s", e)
