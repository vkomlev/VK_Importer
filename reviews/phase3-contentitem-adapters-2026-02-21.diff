+"""в•ЁРів•Ёв•ңв•Ёв••в•ӨР”в•Ёв••в•ӨР–в•Ёв••в•ӨРҗв•Ёв•ӣв•Ёв–“в•Ёв–‘в•Ёв•ңв•Ёв•ңв•Ёв–‘в•ӨРҹ в•Ёв”Өв•Ёв•ӣв•Ёв•қв•Ёв•Ўв•Ёв•ңв•Ёв•ңв•Ёв–‘в•ӨРҹ в•Ёв•қв•Ёв•ӣв•Ёв”Өв•Ёв•Ўв•Ёв•—в•ӨРң в•Ёв•‘в•Ёв•ӣв•Ёв•ңв•ӨР’в•Ёв•Ўв•Ёв•ңв•ӨР’в•Ёв–‘ (Phase 3)."""
+
+from dataclasses import dataclass, field
+from datetime import datetime
+from pathlib import Path
+from typing import Any, Optional
+
+from .video import VideoData
+
+
+@dataclass
+class MediaRef:
+    """в•ЁРұв•ӨР‘в•ӨРӣв•Ёв•—в•Ёв•‘в•Ёв–‘ в•Ёв•ңв•Ёв–‘ в•Ёв•қв•Ёв•Ўв•Ёв”Өв•Ёв••в•Ёв–‘-в•ӨР”в•Ёв–‘в•Ёв•Јв•Ёв•— (в•Ёв–“в•Ёв••в•Ёв”Өв•Ёв•Ўв•Ёв•ӣ, в•Ёв••в•Ёв•–в•Ёв•ӣв•Ёв–’в•ӨРҗв•Ёв–‘в•Ёв•ўв•Ёв•Ўв•Ёв•ңв•Ёв••в•Ёв•Ў в•Ёв•• в•ӨР’.в•Ёв”Ө.)."""
+    type: str  # "video", "image", "audio"
+    path: Optional[Path] = None
+    url: Optional[str] = None
+    metadata: dict = field(default_factory=dict)
+
+    def __post_init__(self):
+        if self.path is not None and not isinstance(self.path, Path):
+            self.path = Path(self.path)
+
+
+@dataclass
+class ContentItem:
+    """в•ЁРҘв•Ёв”Өв•Ёв••в•Ёв•ңв•Ёв–‘в•ӨРҹ в•ӨР‘в•ӨР“в•ӨРҷв•Ёв•ңв•Ёв•ӣв•ӨР‘в•ӨР’в•ӨРң в•Ёв”җв•ӨР“в•Ёв–’в•Ёв•—в•Ёв••в•Ёв•‘в•Ёв–‘в•ӨР–в•Ёв••в•Ёв•• в•Ёв”Өв•Ёв•—в•ӨРҹ в•Ёв•—в•ӨРһв•Ёв–’в•ӨРӣв•ӨР• в•Ёв••в•ӨР‘в•ӨР’в•Ёв•ӣв•ӨР—в•Ёв•ңв•Ёв••в•Ёв•‘в•Ёв•ӣв•Ёв–“ в•Ёв•• в•Ёв•ңв•Ёв–‘в•Ёв”җв•ӨРҗв•Ёв–‘в•Ёв–“в•Ёв•—в•Ёв•Ўв•Ёв•ңв•Ёв••в•Ёв•Ј.
+
+    в•ЁРҜв•Ёв•ӣв•Ёв•–в•Ёв–“в•Ёв•ӣв•Ёв•—в•ӨРҹв•Ёв•Ўв•ӨР’ в•Ёв•ӣв•Ёв”җв•Ёв••в•ӨР‘в•ӨРӣв•Ёв–“в•Ёв–‘в•ӨР’в•ӨРң в•Ёв•‘в•Ёв•ӣв•Ёв•ңв•ӨР’в•Ёв•Ўв•Ёв•ңв•ӨР’ в•Ёв••в•Ёв•– TG, RSS, VK в•Ёв•• в•Ёв”җв•ӨР“в•Ёв–’в•Ёв•—в•Ёв••в•Ёв•‘в•Ёв•ӣв•Ёв–“в•Ёв–‘в•ӨР’в•ӨРң в•Ёв–“ VK, YouTube, в•ЁРӨв•Ёв•–в•Ёв•Ўв•Ёв•ң в•Ёв•• в•ӨР’.в•Ёв”Ө.
+    """
