+
+class DestinationAdapter(ABC):
+    """в•ЁР в•Ёв”Өв•Ёв–‘в•Ёв”җв•ӨР’в•Ёв•Ўв•ӨРҗ в•Ёв•ңв•Ёв–‘в•Ёв”җв•ӨРҗв•Ёв–‘в•Ёв–“в•Ёв•—в•Ёв•Ўв•Ёв•ңв•Ёв••в•ӨРҹ в•Ёв”җв•ӨР“в•Ёв–’в•Ёв•—в•Ёв••в•Ёв•‘в•Ёв–‘в•ӨР–в•Ёв••в•Ёв•• (VK, YouTube, в•ЁРӨв•Ёв•–в•Ёв•Ўв•Ёв•ң, WordPress в•Ёв•• в•ӨР’.в•Ёв”Ө.)."""
+
+    @property
+    @abstractmethod
+    def destination_id(self) -> str:
+        """в•ЁРЁв•Ёв”Өв•Ёв•Ўв•Ёв•ңв•ӨР’в•Ёв••в•ӨР”в•Ёв••в•Ёв•‘в•Ёв–‘в•ӨР’в•Ёв•ӣв•ӨРҗ в•Ёв•ңв•Ёв–‘в•Ёв”җв•ӨРҗв•Ёв–‘в•Ёв–“в•Ёв•—в•Ёв•Ўв•Ёв•ңв•Ёв••в•ӨРҹ (vk, youtube, rutube, ...)."""
+        pass
+
+    @abstractmethod
+    def publish(self, item: ContentItem, **options: object) -> PublicationResult:
+        """в•ЁР®в•Ёв”җв•ӨР“в•Ёв–’в•Ёв•—в•Ёв••в•Ёв•‘в•Ёв•ӣв•Ёв–“в•Ёв–‘в•ӨР’в•ӨРң в•ӨРқв•Ёв•—в•Ёв•Ўв•Ёв•қв•Ёв•Ўв•Ёв•ңв•ӨР’ в•Ёв•‘в•Ёв•ӣв•Ёв•ңв•ӨР’в•Ёв•Ўв•Ёв•ңв•ӨР’в•Ёв–‘ в•Ёв–“ в•Ёв•ңв•Ёв–‘в•Ёв”җв•ӨРҗв•Ёв–‘в•Ёв–“в•Ёв•—в•Ёв•Ўв•Ёв•ңв•Ёв••в•Ёв•Ў.
+
+        Returns:
+            PublicationResult в•ӨР‘ remote_url в•Ёв”җв•ӨРҗв•Ёв•• в•ӨР“в•ӨР‘в•Ёв”җв•Ёв•Ўв•ӨР•в•Ёв•Ў в•Ёв••в•Ёв•—в•Ёв•• error_code в•Ёв”җв•ӨРҗв•Ёв•• в•Ёв•ӣв•ӨРҳв•Ёв••в•Ёв–’в•Ёв•‘в•Ёв•Ў.
+        """
+        pass
