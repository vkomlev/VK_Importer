+"""в•ЁРұв•Ёв•Ўв•ӨРҗв•Ёв–“в•Ёв••в•ӨР‘: в•Ёв•қв•Ёв–‘в•Ёв”җв•Ёв”җв•Ёв••в•Ёв•ңв•Ёв”Ӯ VideoRecord + PublicationResult -> canonical payload в•Ёв•• в•Ёв•–в•Ёв–‘в•Ёв”җв•Ёв••в•ӨР‘в•ӨРң в•Ёв–“ Content Hub."""
+
+import logging
+from datetime import datetime, timezone
+from pathlib import Path
+from typing import Optional
+
+from src.storage.database import VideoRecord
+from src.models.content import PublicationResult
+
+from .models import ContentHubConfig, LinkMapPayload, PublicationPayload
+from .repository import ContentHubRepository
+
+logger = logging.getLogger(__name__)
+
+
+def _global_uid(record: VideoRecord) -> str:
+    """в•ЁРұв•ӨР’в•Ёв–‘в•Ёв–’в•Ёв••в•Ёв•—в•ӨРңв•Ёв•ңв•ӨРӣв•Ёв•Ј source key: vk_importer:video_record:<id> в•Ёв••в•Ёв•—в•Ёв•• fallback vk_importer:path:<path>."""
+    if getattr(record, "id", None) is not None:
+        return f"vk_importer:video_record:{record.id}"
+    path = (record.file_path or "").replace("\\", "/").strip()
+    if path:
+        return f"vk_importer:path:{path}"
+    return f"vk_importer:path:unknown"
+
+
+def _remote_id_from_vk_url(remote_url: Optional[str]) -> Optional[str]:
+    """в•ЁРЁв•Ёв•–в•Ёв–“в•Ёв•—в•Ёв•Ўв•ӨР—в•ӨРң remote_id в•Ёв”Өв•Ёв•—в•ӨРҹ VK в•Ёв••в•Ёв•– URL (в•ӨР”в•Ёв•ӣв•ӨРҗв•Ёв•қв•Ёв–‘в•ӨР’ owner_id_video_id, в•Ёв•ңв•Ёв–‘в•Ёв”җв•ӨРҗв•Ёв••в•Ёв•қв•Ёв•Ўв•ӨРҗ -12345_67890)."""
+    if not remote_url:
+        return None
+    from src.publisher.vk_publisher import VKPublisher
+    pair = VKPublisher.parse_video_url(remote_url)
+    if not pair:
+        return None
+    owner_id, video_id = pair
+    return f"{owner_id}_{video_id}"
+
+
+class ContentHubService:
+    """в•ЁРЎв•Ёв••в•Ёв•–в•Ёв•ңв•Ёв•Ўв•ӨР‘-в•Ёв•қв•ӨРқв•Ёв”җв•Ёв”җв•Ёв••в•Ёв•ңв•Ёв”Ӯ publish-result -> canonical в•Ёв•• в•Ёв–“в•ӨРӣв•Ёв•–в•Ёв•ӣв•Ёв–“ repository."""
+
+    def __init__(self, config: Optional[ContentHubConfig] = None, run_id: Optional[str] = None):
+        self.config = config or ContentHubConfig.from_env()
+        self._repo = ContentHubRepository(self.config, run_id=run_id)
+
+    def write_canonical(
+        self,
+        record: VideoRecord,
+        result: PublicationResult,
+    ) -> None:
+        """
+        в•ЁРҜв•Ёв•ӣв•ӨР‘в•Ёв•—в•Ёв•Ў в•Ёв”җв•ӨР“в•Ёв–’в•Ёв•—в•Ёв••в•Ёв•‘в•Ёв–‘в•ӨР–в•Ёв••в•Ёв•• (в•ӨР“в•ӨР‘в•Ёв”җв•Ёв•Ўв•ӨРҳв•Ёв•ңв•Ёв•ӣв•Ёв•Ј в•Ёв••в•Ёв•—в•Ёв•• в•Ёв•ңв•Ёв•Ўв•ӨР’): upsert в•Ёв–“ publication в•Ёв•• link_map.
+        в•ЁРҜв•ӨРҗв•Ёв•• dry_run в•ӨР’в•Ёв•ӣв•Ёв•—в•ӨРңв•Ёв•‘в•Ёв•ӣ в•Ёв•—в•Ёв•ӣв•Ёв”Ӯв•Ёв••в•ӨРҗв•ӨР“в•Ёв•Ўв•ӨР’ payload, в•Ёв•ңв•Ёв•Ў в•Ёв”җв•Ёв••в•ӨРҳв•Ёв•Ўв•ӨР’ в•Ёв–“ в•ЁРЎв•ЁРӨ.
+        """
+        if not self.config.enabled:
+            return
+        global_uid = _global_uid(record)
+        destination = result.destination or "vk"
+        status = "published" if result.ok else "failed"
+        error = result.error_code if not result.ok else None
+        remote_url = result.remote_url if result.ok else None
+        remote_id = _remote_id_from_vk_url(remote_url) if remote_url else None
+        published_at = datetime.now(timezone.utc) if result.ok else None
+
+        pub = PublicationPayload(
+            global_uid=global_uid,
+            destination=destination,
+            remote_url=remote_url,
+            remote_id=remote_id,
+            status=status,
+            error=error,
+            published_at=published_at,
+        )
+        link = LinkMapPayload(
+            source_global_uid=global_uid,
+            destination=destination,
+            remote_id=remote_id,
+            remote_url=remote_url,
+        )
+
+        if self.config.dry_run:
+            logger.info(
+                "content_hub [dry-run] would upsert: global_uid=%s destination=%s status=%s remote_id=%s",
+                global_uid, destination, status, remote_id,
+                extra={"run_id": self._repo.run_id, "dry_run": True},
+            )
+            self._repo.upsert_publication(pub)  # в•Ёв–“в•Ёв•ңв•ӨР“в•ӨР’в•ӨРҗв•Ёв•• в•Ёв”җв•ӨРҗв•Ёв•ӣв•Ёв–“в•Ёв•Ўв•ӨРҗв•Ёв••в•ӨР’ dry_run в•Ёв•• в•ӨР’в•Ёв•ӣв•Ёв•—в•ӨРңв•Ёв•‘в•Ёв•ӣ в•Ёв•–в•Ёв–‘в•Ёв•—в•Ёв•ӣв•Ёв”Ӯв•Ёв••в•ӨРҗв•ӨР“в•Ёв•Ўв•ӨР’
+            self._repo.upsert_link_map(link)
+            return
+
+        self._repo.upsert_publication(pub)
+        self._repo.upsert_link_map(link)
