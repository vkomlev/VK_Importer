+"""в•ЁР¬в•Ёв•ӣв•Ёв”Өв•Ёв•Ўв•Ёв•—в•Ёв•• в•Ёв•• в•Ёв•‘в•Ёв•ӣв•Ёв•ңв•ӨР”в•Ёв••в•Ёв”Ӯв•ӨР“в•ӨРҗв•Ёв–‘в•ӨР–в•Ёв••в•ӨРҹ Content Hub write-path.
+
+в•ЁРҙв•Ёв–‘в•Ёв•‘в•ӨР’в•Ёв••в•ӨР—в•Ёв•Ўв•ӨР‘в•Ёв•‘в•Ёв–‘в•ӨРҹ в•ӨР‘в•ӨР•в•Ёв•Ўв•Ёв•қв•Ёв–‘ (в•ЁРЎв•ЁРӨ Learn, schema content_hub, в•Ёв”җв•Ёв•ӣв•Ёв•—в•ӨР“в•ӨР—в•Ёв•Ўв•Ёв•ңв•Ёв–‘ в•ӨР—в•Ёв•Ўв•ӨРҗв•Ёв•Ўв•Ёв•– MCP):
+  content_hub.publication:
+    id BIGINT, global_uid TEXT NOT NULL, destination TEXT NOT NULL,
+    remote_id TEXT, remote_url TEXT, published_at TIMESTAMPTZ, status TEXT, error TEXT,
+    created_at TIMESTAMPTZ NOT NULL DEFAULT now(), updated_at TIMESTAMPTZ NOT NULL DEFAULT now(),
+    UNIQUE ix_content_hub_publication_global_uid_destination (global_uid, destination)
+
+  content_hub.link_map:
+    id BIGINT, source_global_uid TEXT NOT NULL, destination TEXT NOT NULL,
+    remote_id TEXT, remote_url TEXT,
+    created_at TIMESTAMPTZ NOT NULL DEFAULT now(),
+    UNIQUE ix_content_hub_link_map_source_dest (source_global_uid, destination)
+  (в•Ёв•‘в•Ёв•ӣв•Ёв•—в•Ёв•ӣв•Ёв•ңв•Ёв•‘в•Ёв•• updated_at в•Ёв–“ link_map в•Ёв•ңв•Ёв•Ўв•ӨР’)
+"""
+
+import os
+from dataclasses import dataclass, field
+from datetime import datetime, timezone
+from pathlib import Path
+from typing import Optional
+
+from src.utils.env_utils import get_env_var
+
+
+@dataclass
+class ContentHubConfig:
+    """в•ЁРӘв•Ёв•ӣв•Ёв•ңв•ӨР”в•Ёв••в•Ёв”Ӯв•ӨР“в•ӨРҗв•Ёв–‘в•ӨР–в•Ёв••в•ӨРҹ в•Ёв•–в•Ёв–‘в•Ёв”җв•Ёв••в•ӨР‘в•Ёв•• в•Ёв–“ Content Hub (в•Ёв••в•Ёв•– env)."""
+
+    enabled: bool = False
+    dry_run: bool = False
+    strict: bool = False  # в•ЁРҜв•ӨРҗв•Ёв•• True в•ӨР‘в•Ёв–’в•Ёв•ӣв•Ёв•Ј canonical write = в•ӨР”в•Ёв–‘в•ӨР’в•Ёв–‘в•Ёв•—в•ӨРңв•Ёв•ңв•Ёв–‘в•ӨРҹ в•Ёв•ӣв•ӨРҳв•Ёв••в•Ёв–’в•Ёв•‘в•Ёв–‘ в•ӨРҳв•Ёв–‘в•Ёв”Ӯв•Ёв–‘
+    dsn: Optional[str] = None
+
+    @classmethod
+    def from_env(cls, env_path: Optional[Path] = None) -> "ContentHubConfig":
+        enabled = (get_env_var("CONTENT_HUB_WRITE_ENABLED", "0", env_path) or "0").strip() == "1"
+        dry_run = (get_env_var("CONTENT_HUB_WRITE_DRY_RUN", "0", env_path) or "0").strip() == "1"
+        strict = (get_env_var("CONTENT_HUB_WRITE_STRICT", "0", env_path) or "0").strip() == "1"
+        dsn = get_env_var("CONTENT_HUB_PG_DSN", env_path=env_path)
+        if not dsn and (get_env_var("PGHOST", env_path=env_path) or os.getenv("PGHOST")):
+            # в•ЁРұв•Ёв•ӣв•Ёв–’в•Ёв••в•ӨРҗв•Ёв–‘в•Ёв•Ўв•Ёв•қ DSN в•Ёв••в•Ёв•– в•ӨР‘в•Ёв•ӣв•ӨР‘в•ӨР’в•Ёв–‘в•Ёв–“в•Ёв•ңв•ӨРӣв•ӨР• в•Ёв”җв•Ёв•Ўв•ӨРҗв•Ёв•Ўв•Ёв•қв•Ёв•Ўв•Ёв•ңв•Ёв•ңв•ӨРӣв•ӨР•
+            host = get_env_var("PGHOST", env_path=env_path) or os.getenv("PGHOST", "")
+            port = get_env_var("PGPORT", env_path=env_path) or os.getenv("PGPORT", "5432")
+            dbname = get_env_var("PGDATABASE", env_path=env_path) or os.getenv("PGDATABASE", "content_hub")
+            user = get_env_var("PGUSER", env_path=env_path) or os.getenv("PGUSER", "")
+            password = get_env_var("PGPASSWORD", env_path=env_path) or os.getenv("PGPASSWORD", "")
+            if user and password:
+                dsn = f"postgresql://{user}:{password}@{host}:{port}/{dbname}"
+            else:
+                dsn = f"postgresql://{host}:{port}/{dbname}" if host else None
+        return cls(enabled=enabled, dry_run=dry_run, strict=strict, dsn=dsn)
+
+
+@dataclass
+class PublicationPayload:
+    """в•ЁРӨв•Ёв–‘в•Ёв•ңв•Ёв•ңв•ӨРӣв•Ёв•Ў в•Ёв”Өв•Ёв•—в•ӨРҹ upsert в•Ёв–“ content_hub.publication."""
+
+    global_uid: str
+    destination: str
+    remote_url: Optional[str] = None
+    remote_id: Optional[str] = None
+    status: str = "failed"  # published | failed
+    error: Optional[str] = None
+    published_at: Optional[datetime] = None
+
+
+@dataclass
+class LinkMapPayload:
+    """в•ЁРӨв•Ёв–‘в•Ёв•ңв•Ёв•ңв•ӨРӣв•Ёв•Ў в•Ёв”Өв•Ёв•—в•ӨРҹ upsert в•Ёв–“ content_hub.link_map (в•Ёв•‘в•Ёв•ӣв•Ёв•—в•Ёв•ӣв•Ёв•ңв•Ёв•‘в•Ёв–‘ source_global_uid)."""
+
+    source_global_uid: str
+    destination: str
+    remote_id: Optional[str] = None
+    remote_url: Optional[str] = None
